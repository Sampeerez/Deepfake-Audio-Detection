# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Virtual environments ────────────────────────────────
.venv/
venv/
env/

# ── Datasets & generated artifacts (regenerable) ────────
data/
cache/

# ── Pretrained model weights ────────────────────────────────────────────
# The model zoo is small (~4 MB of classic .joblib + a few MB per CNN .pth), so
# it is COMMITTED to the repo and loaded from models/ directly — no Hugging Face
# download at runtime. Only the multi-GB DATASETS still live on HF.
# (demo_leaderboard.json is also committed so the hub can show the comparison.)
# Stray .pth/.joblib/.pkl OUTSIDE models/ (e.g. ad-hoc checkpoints at the repo
# root) stay ignored; the tracked weights live under models/.
/*.pth
/*.joblib
/*.pkl
asvspoof_model_checkpoint.pth

# ── Bundled sample clips ─────────────────────────────────────────────────
# The small committed samples/ tree (train/dev + a tiny eval fallback) IS
# tracked so the web demo always has audio. The runtime cache of eval clips
# streamed from the external Hugging Face dataset is NOT.
samples/_hf_cache/

# ── Secrets & local settings ────────────────────────────
.env
.env.*
.streamlit/secrets.toml
.claude/settings.local.json

# ── Logs ────────────────────────────────────────────────
*.log

# ── OS & editor cruft ───────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
